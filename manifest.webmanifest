<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#100b08" />
  <title>Ascension — Ylinor</title>
  <link rel="manifest" href="manifest.webmanifest" />
  <link rel="icon" href="icon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="concept-backdrop" aria-hidden="true"></div>
  <div class="grain" aria-hidden="true"></div>
  <div class="fog fog-a" aria-hidden="true"></div>
  <div class="fog fog-b" aria-hidden="true"></div>
  <div id="embers" class="embers" aria-hidden="true"></div>
  <div id="soulFragments" class="soul-fragments" aria-hidden="true"></div>

  <header class="topbar">
    <div class="brand-block">
      <p class="eyebrow">Chroniques d’Ylinor</p>
      <h1>ASCENSION</h1>
      <span class="brand-sub">✦ YLINOR ✦</span>
    </div>
    <div class="primaris-sigil" title="Sceau des Primaris">◈</div>
    <div class="player-summary">
      <div><span id="topName">Pierre</span><small id="topTitle">Le Novice</small></div>
      <div class="level-orb"><strong id="topLevel">1</strong><small>NIVEAU</small></div>
      <div class="top-resource">💠 <b id="topSoulCount">0</b><small>Fragments</small></div>
      <div class="top-resource">🪙 <b id="topGoldCount">0</b><small>Or</small></div>
    </div>
  </header>

  <nav class="nav" id="nav"></nav>

  <aside class="primaris-rail left-rail" aria-label="Primaris">
    <div><span class="sigil blue">✥</span><b>CÉLÉAS</b><small>l’ordre</small></div>
    <div><span class="sigil amber">✺</span><b>VINRAËS</b><small>la connaissance</small></div>
    <div><span class="sigil gold">♢</span><b>MÉLÉNAS</b><small>l’équilibre</small></div>
  </aside>
  <aside class="primaris-rail right-rail" aria-label="Forces d’Ylinor">
    <div><span class="sigil red">⌁</span><b>SWADOH</b><small>la discipline</small></div>
    <div><span class="sigil violet">✧</span><b>ANDARË</b><small>la création</small></div>
    <div><span class="sigil cyan">⌬</span><b>ÉTHÉRIENS</b><small>l’innovation</small></div>
  </aside>

  <main>
    <section class="view active" id="dashboardView">
      <div class="hero-grid">
        <article class="panel character-card engraved">
          <div class="avatar-wrap">
            <div class="avatar-stage compact" id="avatarPreview"></div>
            <button class="ghost" data-action="open-avatar">Personnaliser</button>
          </div>
          <div class="character-info">
            <p class="eyebrow">Émissaire d’Ylinor</p>
            <h2 id="characterName">Pierre</h2>
            <p id="characterTitle">Le Novice</p>
            <div class="xp-block">
              <div class="xp-line"><span>Rang <b id="rankLabel">F</b></span><span><b id="xpLabel">0</b> / <span id="xpNextLabel">100</span> XP</span></div>
              <div class="progress"><i id="xpBar"></i></div>
            </div>
            <div class="currency-row">
              <span>💠 <b id="soulCount">0</b> fragments</span>
              <span>🪙 <b id="goldCount">0</b> or</span>
              <span>🔥 <b id="streakCount">0</b> jours</span>
            </div>
          </div>
        </article>

        <article class="panel featured-quest engraved">
          <p class="eyebrow">Quête mise en avant</p>
          <div id="featuredQuest"></div>
        </article>
      </div>

      <div class="dashboard-grid">
        <article class="panel engraved">
          <div class="section-title"><h3>Quêtes du jour</h3><button class="small" data-action="new-quest">+ Ajouter</button></div>
          <div id="dailyQuestList" class="quest-list"></div>
        </article>
        <article class="panel engraved">
          <div class="section-title"><h3>Vertus d’Ylinor</h3><button class="small" data-nav="character">Voir tout</button></div>
          <div id="statMiniGrid" class="stat-mini-grid"></div>
        </article>
        <article class="panel world-panel engraved">
          <div class="section-title"><h3>État du monde</h3><button class="small" data-nav="world">Explorer</button></div>
          <div id="worldMini"></div>
        </article>
        <article class="panel engraved">
          <div class="section-title"><h3>Chronique récente</h3><button class="small" data-nav="journal">Journal</button></div>
          <div id="recentJournal" class="journal-snippet"></div>
        </article>
      </div>
    </section>

    <section class="view" id="questsView">
      <div class="section-header"><div><p class="eyebrow">Le registre des épreuves</p><h2>Quêtes</h2></div><button class="primary" data-action="new-quest">Créer une quête</button></div>
      <div class="tabs" id="questTabs"></div><div id="questBoard" class="quest-board"></div>
    </section>

    <section class="view" id="characterView">
      <div class="section-header"><div><p class="eyebrow">Portrait de l’Ascendant</p><h2>Personnage</h2></div></div>
      <div class="character-layout">
        <article class="panel portrait-panel engraved">
          <div class="avatar-stage large" id="avatarLarge"></div>
          <h3 id="profileName">Pierre</h3><p id="profileTitle">Le Novice</p>
          <button class="primary" data-action="open-avatar">Changer le personnage</button>
        </article>
        <article class="panel engraved"><h3>Les dix Vertus</h3><div id="statsGrid" class="stats-grid"></div></article>
      </div>
    </section>

    <section class="view" id="worldView"><div class="section-header"><div><p class="eyebrow">Carte vivante</p><h2>Ylinor</h2></div><span id="worldProgressText"></span></div><div id="worldMap" class="world-map"></div></section>
    <section class="view" id="shopView"><div class="section-header"><div><p class="eyebrow">Marché des fragments</p><h2>Boutique</h2></div><div class="wallet">💠 <b id="shopSoulCount">0</b> · 🪙 <b id="shopGoldCount">0</b></div></div><div id="shopGrid" class="shop-grid"></div></section>
    <section class="view" id="achievementsView"><div class="section-header"><div><p class="eyebrow">Mémoire du royaume</p><h2>Succès & trophées</h2></div><span id="achievementCount"></span></div><div id="achievementGrid" class="achievement-grid"></div></section>
    <section class="view" id="calendarView"><div class="section-header"><div><p class="eyebrow">Rythme de l’Ascension</p><h2>Calendrier</h2></div><div>🔥 Série actuelle : <b id="calendarStreak">0</b></div></div><div class="calendar-layout"><article class="panel engraved"><div class="calendar-head"><button class="ghost" data-action="prev-month">←</button><h3 id="calendarTitle"></h3><button class="ghost" data-action="next-month">→</button></div><div id="calendarGrid" class="calendar-grid"></div></article><article class="panel engraved"><h3>Récompenses de série</h3><div id="streakRewards"></div></article></div></section>
    <section class="view" id="journalView"><div class="section-header"><div><p class="eyebrow">Les chroniques</p><h2>Journal</h2></div><button class="primary" data-action="add-journal">Écrire une entrée</button></div><div id="journalList" class="journal-list"></div></section>
  </main>

  <dialog id="questDialog"><form method="dialog" id="questForm"><div class="dialog-head"><h3>Nouvelle quête</h3><button value="cancel" class="icon-btn">✕</button></div><label>Titre<input name="title" required maxlength="80" placeholder="Ex. Façonner la Grotte" /></label><label>Description<textarea name="description" maxlength="240" placeholder="Décris l’épreuve..."></textarea></label><div class="form-grid"><label>Type<select name="type"><option value="daily">Quotidienne</option><option value="weekly">Hebdomadaire</option><option value="epic">Épique</option></select></label><label>Difficulté<select name="difficulty"><option value="1">★</option><option value="2">★★</option><option value="3">★★★</option><option value="4">★★★★</option><option value="5">★★★★★</option></select></label><label>Vertu<select name="stat" id="questStatSelect"></select></label><label>XP<input name="xp" type="number" min="10" max="1000" value="50" /></label></div><menu><button value="cancel" class="ghost">Annuler</button><button value="default" class="primary">Créer</button></menu></form></dialog>

  <dialog id="avatarDialog" class="avatar-dialog"><form method="dialog" id="avatarForm"><div class="dialog-head"><div><p class="eyebrow">Atelier des formes</p><h3>Façonner l’Ascendant</h3></div><button value="cancel" class="icon-btn">✕</button></div><div class="avatar-editor"><div class="avatar-editor-preview"><div class="avatar-stage editor" id="avatarEditorPreview"></div><p class="editor-hint">Chaque partie est indépendante : tête, cheveux, torse, bras, jambes et accessoires.</p></div><div class="avatar-controls"><div class="identity-grid"><label>Nom<input name="name" maxlength="30" /></label><label>Titre<input name="title" maxlength="50" /></label></div><div id="avatarPartControls"></div><div class="color-grid"><label>Peau<input type="color" name="skin" /></label><label>Cheveux<input type="color" name="hairColor" /></label><label>Tenue<input type="color" name="clothColor" /></label><label>Métal<input type="color" name="metalColor" /></label><label>Aura<input type="color" name="auraColor" /></label></div></div></div><menu><button value="cancel" class="ghost">Annuler</button><button value="default" class="primary">Sceller l’apparence</button></menu></form></dialog>

  <dialog id="journalDialog"><form method="dialog" id="journalForm"><div class="dialog-head"><h3>Nouvelle chronique</h3><button value="cancel" class="icon-btn">✕</button></div><label>Titre<input name="title" required maxlength="80" /></label><label>Texte<textarea name="text" required maxlength="700"></textarea></label><menu><button value="cancel" class="ghost">Annuler</button><button value="default" class="primary">Sceller l’entrée</button></menu></form></dialog>

  <div id="toast" class="toast"></div>
  <script src="app.js"></script>
</body>
</html>
